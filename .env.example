# ============================================================
# 自动化测试框架 - 环境变量配置模板
# 复制此文件为 .env 并填入实际值
# ============================================================

# -------------------- 数据库配置 --------------------
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=test
DB_CHARSET=utf8

# -------------------- 邮件配置 --------------------
SMTP_HOST=smtp.qq.com
SMTP_PORT=465
SMTP_USER=your_email@qq.com
SMTP_PASSWORD=your授权码_here
SENDER_NAME=自动化测试团队

# -------------------- 测试环境配置 --------------------
TEST_ENV=dev
TEST_URL=https://your-test-url.com
BROWSER=chrome
HEADLESS=false

# -------------------- 报告配置 --------------------
REPORT_TYPE=HTML
ALLURE_RESULTS_PATH=Reports/ALLURE/Result
ALLURE_REPORT_PATH=Reports/ALLURE/Report

# -------------------- 日志配置 --------------------
LOG_LEVEL=INFO
LOG_PATH=Log
LOG_RETENTION_DAYS=30

# -------------------- 安全配置 --------------------
# 是否发送邮件通知
SEND_EMAIL=true

# 是否启用SSL
SMTP_SSL=true

# API密钥（用于加密敏感数据）
API_SECRET_KEY=your-secret-key-here

# -------------------- SSH配置 --------------------
SSH_HOST=your-ssh-server.com
SSH_PORT=22
SSH_USER=your-username
SSH_PASSWORD=your-password

# -------------------- 第三方服务（可选） --------------------
# JIRA配置
JIRA_URL=https://your-jira-server.com
JIRA_USER=your-jira-user
JIRA_TOKEN=your-jira-token

# 企业微信/钉钉通知
WECOM_WEBHOOK=https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
DINGTALK_WEBHOOK=https://oapi.dingtalk.com/robot/send?access_token=xxx
